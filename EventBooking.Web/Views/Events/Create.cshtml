@model EventBooking.BLL.DTOs.CreateEventDto
@{
    ViewData["Title"] = "Create Event";
    Layout = "_TailwindLayout";
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
        <div class="bg-blue-600 text-white px-6 py-4">
            <div class="flex items-center gap-2 mb-1">
                <i data-lucide="ticket" class="size-6"></i>
                <h4 class="text-xl font-bold">Create New Event</h4>
            </div>
            <p class="text-blue-100 text-sm">Starts as <strong>Draft</strong> — publish after adding ticket categories</p>
        </div>
        <div class="p-6 sm:p-8">

            @if (TempData["Error"] != null)
            {
                <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <i data-lucide="alert-circle" class="h-5 w-5 text-red-400"></i>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm text-red-700">@TempData["Error"]</p>
                        </div>
                    </div>
                </div>
            }

            <form asp-action="Create" method="post" class="space-y-6">
                @Html.AntiForgeryToken()

                <div>
                    <label asp-for="Title" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <input asp-for="Title" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" placeholder="Event title" required />
                    <span asp-validation-for="Title" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    <textarea asp-for="Description" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" rows="3" placeholder="Describe the event"></textarea>
                    <span asp-validation-for="Description" class="text-red-500 text-xs mt-1 block"></span>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Category" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        <select asp-for="Category" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white" required>
                            <option value="">— Select category —</option>
                            @foreach (var c in new[]{"Music", "Technology", "Food", "Art", "Sports", "Entertainment", "Business"})
                            { <option value="@c">@c</option> }
                        </select>
                        <span asp-validation-for="Category" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Venue" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        <input asp-for="Venue" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" placeholder="Venue / location" />
                        <span asp-validation-for="Venue" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label asp-for="Date" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        <input asp-for="Date" type="datetime-local" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required />
                        <span asp-validation-for="Date" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Capacity" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        <input asp-for="Capacity" type="number" min="1" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required />
                        <span asp-validation-for="Capacity" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="Price" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <span class="text-gray-500 sm:text-sm">$</span>
                            </div>
                            <input asp-for="Price" type="number" step="0.01" min="0" class="w-full pl-7 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required />
                        </div>
                        <span asp-validation-for="Price" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                </div>

                <div class="flex items-center gap-3 pt-4">
                    <button type="submit" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg hover:bg-blue-700 transition-colors font-medium shadow-sm">
                        Create Draft
                    </button>
                    <a asp-action="Index" asp-controller="Organizer" class="px-6 py-2.5 text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors font-medium">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
