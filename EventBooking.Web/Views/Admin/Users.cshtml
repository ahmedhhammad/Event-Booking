@model IEnumerable<EventBooking.BLL.DTOs.UserAdminDto>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex" style="min-height:calc(100vh - 62px)">
    <aside style="width:240px; background:#1e293b; flex-shrink:0; position:sticky; top:62px; height:calc(100vh - 62px); overflow-y:auto">
        <div class="p-4">
            <div class="text-white fw-bold mb-4">⚙ Admin Panel</div>
            <nav class="d-flex flex-column gap-1">
                <a asp-controller="Admin" asp-action="Index"   class="d-flex align-items-center gap-2 px-3 py-2 rounded text-decoration-none fw-medium" style="color:#94a3b8">📊 Dashboard</a>
                <a asp-controller="Admin" asp-action="Events"  class="d-flex align-items-center gap-2 px-3 py-2 rounded text-decoration-none fw-medium" style="color:#94a3b8">🎭 Events</a>
                <a asp-controller="Admin" asp-action="Users"   class="d-flex align-items-center gap-2 px-3 py-2 rounded text-decoration-none fw-medium" style="color:#fff; background:#3B82F6">👥 Users</a>
                <a asp-controller="Admin" asp-action="Reports" class="d-flex align-items-center gap-2 px-3 py-2 rounded text-decoration-none fw-medium" style="color:#94a3b8">📈 Reports</a>
            </nav>
        </div>
    </aside>

    <main class="flex-grow-1 p-4" style="background:#f8fafc">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold mb-0">User Management</h4>
                <p class="text-muted small mb-0">@Model.Count() registered users</p>
            </div>
        </div>

        <div class="card border-0 shadow-sm" style="border-radius:12px">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead style="background:#1e293b; color:#fff">
                        <tr>
                            <th class="px-4 py-3">ID</th>
                            <th class="py-3">Name</th>
                            <th class="py-3">Email</th>
                            <th class="py-3">Role</th>
                            <th class="py-3">Change Role</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td class="px-4 py-3 text-muted small">@u.UserId</td>
                                <td class="py-3 fw-semibold">@u.Name</td>
                                <td class="py-3 text-muted">@u.Email</td>
                                <td class="py-3">
                                    <span class="badge @(u.Role == "Admin" ? "bg-danger" : u.Role == "Organizer" ? "bg-warning text-dark" : "bg-primary")">
                                        @u.Role
                                    </span>
                                </td>
                                <td class="py-3">
                                    @if (u.Role != "Admin")
                                    {
                                        <form asp-action="ChangeRole" method="post" class="d-flex align-items-center gap-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@u.UserId" />
                                            <select name="newRole" class="form-select form-select-sm" style="width:130px">
                                                @if (u.Role == "Attendee")
                                                {
                                                    <option value="Attendee" selected>Attendee</option>
                                                    <option value="Organizer">Organizer</option>
                                                }
                                                else
                                                {
                                                    <option value="Attendee">Attendee</option>
                                                    <option value="Organizer" selected>Organizer</option>
                                                }
                                            </select>
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Save</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Protected</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
