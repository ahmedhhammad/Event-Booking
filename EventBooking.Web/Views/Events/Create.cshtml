@model EventBooking.BLL.DTOs.CreateEventDto
@{
    ViewData["Title"] = "Create Event";
}

<div class="container py-4" style="max-width:700px">
    <div class="card shadow-sm border-0">
        <div class="card-header text-white py-3" style="background: linear-gradient(135deg,#6c63ff,#48c6ef)">
            <h4 class="mb-0 fw-bold">🎟 Create New Event</h4>
            <small class="opacity-75">Starts as <strong>Draft</strong> — publish after adding ticket categories</small>
        </div>
        <div class="card-body p-4">

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    @TempData["Error"]
                    <button class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-semibold"></label>
                    <input asp-for="Title" class="form-control" placeholder="Event title" required />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-semibold"></label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe the event"></textarea>
                    <span asp-validation-for="Description" class="text-danger small"></span>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Category" class="form-label fw-semibold"></label>
                        <select asp-for="Category" class="form-select" required>
                            <option value="">— Select category —</option>
                            @foreach (var c in new[]{"Conference","Workshop","Concert","Sports","Festival","Other"})
                            { <option value="@c">@c</option> }
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Venue" class="form-label fw-semibold"></label>
                        <input asp-for="Venue" class="form-control" placeholder="Venue / location" />
                    </div>
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label asp-for="Date" class="form-label fw-semibold"></label>
                        <input asp-for="Date" type="datetime-local" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Capacity" class="form-label fw-semibold"></label>
                        <input asp-for="Capacity" type="number" min="1" class="form-control" required />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="Price" class="form-label fw-semibold"></label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="Price" type="number" step="0.01" min="0" class="form-control" required />
                        </div>
                    </div>
                </div>

                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn text-white fw-bold px-4"
                            style="background:linear-gradient(135deg,#6c63ff,#48c6ef)">
                        Create Draft
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>
