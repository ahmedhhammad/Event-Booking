@model EventBooking.Web.Models.EventListViewModel
@using EventBooking.BLL.DTOs

@{
    ViewData["Title"] = "Events";
    var q = Model.Query;
    var pr = Model.PagedResult;

    // Helper: build page link preserving all query params
    string PageUrl(int page) =>
        $"?searchTerm={Uri.EscapeDataString(q.SearchTerm ?? "")}" +
        $"&category={Uri.EscapeDataString(q.Category ?? "")}" +
        $"&sortBy={Uri.EscapeDataString(q.SortBy ?? "date")}" +
        $"&sortDesc={q.SortDesc}" +
        $"&page={page}" +
        $"&pageSize={q.PageSize}";

    int startItem = pr.TotalCount == 0 ? 0 : (q.Page - 1) * q.PageSize + 1;
    int endItem   = Math.Min(q.Page * q.PageSize, pr.TotalCount);

    // Pagination window
    int windowSize = 5;
    int halfWindow = windowSize / 2;
    int startPage  = Math.Max(1, q.Page - halfWindow);
    int endPage    = Math.Min(pr.TotalPages, startPage + windowSize - 1);
    if (endPage - startPage + 1 < windowSize)
        startPage = Math.Max(1, endPage - windowSize + 1);
}

<style>
    :root {
        --primary: #6c63ff;
        --primary-dark: #574fd6;
        --surface: #ffffff;
        --bg: #f0f2ff;
        --text-muted: #6c757d;
        --radius: 14px;
        --card-shadow: 0 4px 24px rgba(108,99,255,.10);
        --card-hover-shadow: 0 8px 36px rgba(108,99,255,.22);
    }

    body { background: var(--bg); }

    /* ── Page header ── */
    .events-header {
        background: linear-gradient(135deg, #6c63ff 0%, #48c6ef 100%);
        border-radius: var(--radius);
        color: #fff;
        padding: 2.5rem 2rem 2rem;
        margin-bottom: 2rem;
    }
    .events-header h1 { font-weight: 700; margin-bottom: .25rem; }
    .events-header p  { opacity: .88; margin: 0; }

    /* ── Filter bar ── */
    .filter-bar {
        background: var(--surface);
        border-radius: var(--radius);
        box-shadow: var(--card-shadow);
        padding: 1.25rem 1.5rem;
        margin-bottom: 2rem;
    }
    .filter-bar .form-control,
    .filter-bar .form-select {
        border-radius: 8px;
        border: 1.5px solid #e0e3ff;
        transition: border-color .2s;
    }
    .filter-bar .form-control:focus,
    .filter-bar .form-select:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px rgba(108,99,255,.12);
    }
    .btn-search {
        background: linear-gradient(135deg, #6c63ff, #48c6ef);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: .5rem 1.4rem;
        font-weight: 600;
        transition: opacity .2s, transform .15s;
    }
    .btn-search:hover { opacity: .9; transform: translateY(-1px); color: #fff; }
    .btn-clear {
        border-radius: 8px;
        border: 1.5px solid #dee2e6;
        background: transparent;
        padding: .5rem 1.1rem;
        transition: background .2s;
    }
    .btn-clear:hover { background: #f8f9fa; }

    /* ── Event cards ── */
    .event-card {
        background: var(--surface);
        border: none;
        border-radius: var(--radius);
        box-shadow: var(--card-shadow);
        transition: transform .22s ease, box-shadow .22s ease;
        overflow: hidden;
        height: 100%;
    }
    .event-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--card-hover-shadow);
    }
    .event-card-accent {
        height: 5px;
        background: linear-gradient(90deg, #6c63ff, #48c6ef);
    }
    .card-body { padding: 1.4rem; }
    .event-title {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: .5rem;
        line-height: 1.35;
    }
    .badge-category {
        background: rgba(108,99,255,.12);
        color: var(--primary);
        font-size: .72rem;
        font-weight: 600;
        border-radius: 20px;
        padding: .25em .75em;
        letter-spacing: .03em;
    }
    .event-meta {
        font-size: .82rem;
        color: var(--text-muted);
        margin-bottom: .25rem;
        display: flex;
        align-items: center;
        gap: .35rem;
    }
    .event-meta svg { flex-shrink: 0; }
    .event-price {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--primary);
        margin-top: .75rem;
    }
    .btn-view {
        background: linear-gradient(135deg, #6c63ff, #48c6ef);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: .85rem;
        font-weight: 600;
        padding: .45rem 1.1rem;
        transition: opacity .2s, transform .15s;
        width: 100%;
        margin-top: .85rem;
    }
    .btn-view:hover { opacity: .88; transform: translateY(-1px); color: #fff; }

    /* ── Empty state ── */
    .empty-state {
        background: var(--surface);
        border-radius: var(--radius);
        box-shadow: var(--card-shadow);
        padding: 4rem 2rem;
        text-align: center;
        color: var(--text-muted);
    }
    .empty-state-icon { font-size: 3.5rem; margin-bottom: 1rem; }

    /* ── Pagination ── */
    .page-link {
        border-radius: 8px !important;
        margin: 0 2px;
        border: 1.5px solid #e0e3ff;
        color: var(--primary);
        font-weight: 500;
        transition: all .15s;
    }
    .page-link:hover { background: rgba(108,99,255,.08); border-color: var(--primary); }
    .page-item.active .page-link {
        background: linear-gradient(135deg, #6c63ff, #48c6ef);
        border-color: transparent;
        color: #fff;
        box-shadow: 0 2px 8px rgba(108,99,255,.35);
    }
    .page-item.disabled .page-link { color: #adb5bd; border-color: #f0f0f0; }
    .pagination-info { font-size: .85rem; color: var(--text-muted); }
</style>

<!-- ── TempData Alerts ── -->
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" id="alert-success">
        <strong>✓</strong> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="alert-error">
        <strong>⚠</strong> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- ── Page Header ── -->
<div class="events-header">
    <h1>🎟 Upcoming Events</h1>
    <p>Discover and book the best events near you</p>
</div>

<!-- ── Search / Filter / Sort Bar ── -->
<div class="filter-bar">
    <form method="get" action="@Url.Action("Index", "Events")" id="filter-form">
        <input type="hidden" name="page" value="1" />
        <div class="row g-2 align-items-end">

            <div class="col-12 col-md-4">
                <label class="form-label fw-semibold small mb-1" for="searchTerm">Search</label>
                <input type="text"
                       id="searchTerm"
                       name="searchTerm"
                       class="form-control"
                       placeholder="Search events by title or description..."
                       value="@q.SearchTerm" />
            </div>

            <div class="col-6 col-md-3">
                <label class="form-label fw-semibold small mb-1" for="category">Category</label>
                <select id="category" name="category" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var cat in Model.Categories)
                    {
                        <option value="@cat" selected="@(q.Category == cat ? "selected" : null)">@cat</option>
                    }
                </select>
            </div>

            <div class="col-6 col-md-2">
                <label class="form-label fw-semibold small mb-1" for="sortBy">Sort By</label>
                <select id="sortBy" name="sortBy" class="form-select">
                    <option value="date"  selected="@(q.SortBy == "date"  ? "selected" : null)">Date</option>
                    <option value="title" selected="@(q.SortBy == "title" ? "selected" : null)">Title</option>
                    <option value="price" selected="@(q.SortBy == "price" ? "selected" : null)">Price</option>
                </select>
            </div>

            <div class="col-auto">
                <label class="form-label fw-semibold small mb-1 d-block" for="sortDesc">Order</label>
                <select id="sortDesc" name="sortDesc" class="form-select">
                    <option value="false" selected="@(!q.SortDesc ? "selected" : null)">Ascending</option>
                    <option value="true"  selected="@(q.SortDesc  ? "selected" : null)">Descending</option>
                </select>
            </div>

            <div class="col-auto d-flex gap-2">
                <button type="submit" class="btn btn-search" id="btn-search">Search</button>
                <a href="@Url.Action("Index", "Events")" class="btn btn-clear" id="btn-clear">Clear</a>
            </div>
        </div>
    </form>
</div>

<!-- ── Results Count ── -->
@if (pr.TotalCount > 0)
{
    <p class="pagination-info mb-3 ps-1">
        Showing <strong>@startItem–@endItem</strong> of <strong>@pr.TotalCount</strong> event@(pr.TotalCount == 1 ? "" : "s")
        @if (!string.IsNullOrWhiteSpace(q.SearchTerm))
        {
            <span> matching "<em>@q.SearchTerm</em>"</span>
        }
    </p>
}

<!-- ── Events Grid ── -->
@if (!pr.Items.Any())
{
    <div class="empty-state">
        <div class="empty-state-icon">🔍</div>
        <h4 class="fw-bold text-dark">No events found</h4>
        <p class="mb-3">Try adjusting your search or filters.</p>
        <a href="@Url.Action("Index", "Events")" class="btn btn-search px-4" id="btn-view-all">View All Events</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4" id="events-grid">
        @foreach (var e in pr.Items)
        {
            <div class="col">
                <div class="event-card card" id="event-@e.EventId">
                    <div class="event-card-accent"></div>
                    <div class="card-body d-flex flex-column">

                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <span class="badge-category">@e.Category</span>
                        </div>

                        <h5 class="event-title">@e.Title</h5>

                        <div class="event-meta">
                            <!-- Calendar icon -->
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                            @e.Date.ToString("dd MMM yyyy")
                        </div>

                        <div class="event-meta">
                            <!-- Location icon -->
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0 1 18 0z"></path>
                                <circle cx="12" cy="10" r="3"></circle>
                            </svg>
                            @e.Venue
                        </div>

                        <div class="event-meta">
                            <!-- People icon -->
                            <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
                                <circle cx="9" cy="7" r="4"></circle>
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87"></path>
                                <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
                            </svg>
                            Capacity: @e.Capacity
                        </div>

                        <div class="mt-auto">
                            <div class="event-price">@e.Price.ToString("C")</div>
                            <a asp-controller="Events"
                               asp-action="Details"
                               asp-route-id="@e.EventId"
                               class="btn btn-view"
                               id="btn-details-@e.EventId">
                                View Details →
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>

    <!-- ── Pagination ── -->
    @if (pr.TotalPages > 1)
    {
        <nav aria-label="Events pagination" class="mt-4">
            <ul class="pagination justify-content-center flex-wrap">

                <!-- Previous -->
                <li class="page-item @(!pr.HasPrevious ? "disabled" : "")">
                    <a class="page-link"
                       href="@(!pr.HasPrevious ? "#" : PageUrl(q.Page - 1))"
                       id="btn-prev"
                       aria-label="Previous">
                        ‹ Prev
                    </a>
                </li>

                <!-- Page numbers -->
                @for (int p = startPage; p <= endPage; p++)
                {
                    <li class="page-item @(p == q.Page ? "active" : "")">
                        <a class="page-link"
                           href="@PageUrl(p)"
                           id="btn-page-@p"
                           aria-label="Page @p"
                           aria-current="@(p == q.Page ? "page" : null)">
                            @p
                        </a>
                    </li>
                }

                <!-- Next -->
                <li class="page-item @(!pr.HasNext ? "disabled" : "")">
                    <a class="page-link"
                       href="@(!pr.HasNext ? "#" : PageUrl(q.Page + 1))"
                       id="btn-next"
                       aria-label="Next">
                        Next ›
                    </a>
                </li>

            </ul>

            <p class="text-center pagination-info mt-1">
                Page <strong>@q.Page</strong> of <strong>@pr.TotalPages</strong>
                &nbsp;·&nbsp; @pr.TotalCount event@(pr.TotalCount == 1 ? "" : "s") total
            </p>
        </nav>
    }
}
