@model EventBooking.BLL.DTOs.AttendanceSummaryDto
@{
    ViewData["Title"] = "Attendance";
    double pct = Model.TotalSold > 0 ? Math.Round((double)Model.TotalCheckedIn / Model.TotalSold * 100, 1) : 0;
}

<div class="container py-4" style="max-width:700px">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">📊 Attendance Summary</h3>
        <a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-outline-secondary btn-sm">← Back to Event</a>
    </div>

    <!-- Summary cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-primary">@Model.TotalSold</div>
                <small class="text-muted">Tickets Sold</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-success">@Model.TotalCheckedIn</div>
                <small class="text-muted">Checked In</small>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-3">
                <div class="fs-2 fw-bold text-info">@pct%</div>
                <small class="text-muted">Check-in Rate</small>
            </div>
        </div>
    </div>

    <!-- Progress bar -->
    <div class="mb-4">
        <div class="progress" style="height:12px; border-radius:6px">
            <div class="progress-bar bg-success"
                 role="progressbar"
                 style="width:@pct%"
                 aria-valuenow="@pct" aria-valuemin="0" aria-valuemax="100">
            </div>
        </div>
    </div>

    <!-- Per-category breakdown -->
    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead style="background:linear-gradient(135deg,#6c63ff,#48c6ef); color:#fff">
                    <tr><th>Category</th><th>Sold</th><th>Checked In</th><th>Rate</th></tr>
                </thead>
                <tbody>
                    @foreach (var line in Model.Categories)
                    {
                        double catPct = line.QuantitySold > 0
                            ? Math.Round((double)line.CheckedIn / line.QuantitySold * 100, 1) : 0;
                        <tr>
                            <td class="fw-semibold">@line.Name</td>
                            <td>@line.QuantitySold</td>
                            <td>@line.CheckedIn</td>
                            <td>
                                <div class="progress" style="height:8px; border-radius:4px; min-width:80px">
                                    <div class="progress-bar bg-info" style="width:@catPct%"></div>
                                </div>
                                <small class="text-muted">@catPct%</small>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (!Model.Categories.Any())
    {
        <div class="alert alert-info mt-3">No ticket categories yet.</div>
    }
</div>
