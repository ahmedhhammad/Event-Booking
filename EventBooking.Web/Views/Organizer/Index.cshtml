@model IEnumerable<EventBooking.BLL.DTOs.EventDto>
@{
    ViewData["Title"] = "Organizer Hub";
    var name = User.Identity?.Name ?? "Organizer";
    var events = Model.ToList();
}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="card border-0 shadow-sm p-4" style="border-radius:12px; position:sticky; top:24px">
                <div class="d-flex align-items-center gap-3 mb-4 pb-4 border-bottom">
                    <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold"
                         style="width:48px;height:48px;font-size:1.2rem;background:linear-gradient(135deg,#6c63ff,#48c6ef)">
                        @name.Substring(0, 1).ToUpper()
                    </div>
                    <div>
                        <div class="fw-semibold">@name</div>
                        <span class="badge" style="background:#6c63ff;font-size:.65rem">Organizer</span>
                    </div>
                </div>
                <nav class="d-flex flex-column gap-2">
                    <a asp-controller="Organizer" asp-action="Index"
                       class="btn btn-outline-primary text-start fw-semibold">🏠 Hub</a>
                    <a asp-controller="Events" asp-action="Create"
                       class="btn text-white text-start fw-semibold"
                       style="background:linear-gradient(135deg,#6c63ff,#48c6ef)">+ Create Event</a>
                    <a asp-controller="Events" asp-action="Index"
                       class="btn btn-light text-start">📋 All Events</a>
                    <hr />
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger w-100 text-start">🚪 Logout</button>
                    </form>
                </nav>
            </div>
        </div>

        <!-- Content -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h3 class="fw-bold mb-0">Welcome, @name.Split(' ')[0]! 🗓</h3>
                    <p class="text-muted mb-0">@events.Count event(s) — click an action to manage it</p>
                </div>
                <a asp-controller="Events" asp-action="Create"
                   class="btn text-white fw-bold px-4"
                   style="background:linear-gradient(135deg,#6c63ff,#48c6ef)">+ Create Event</a>
            </div>

            @if (!events.Any())
            {
                <div class="card border-0 shadow-sm p-5 text-center" style="border-radius:12px">
                    <div style="font-size:3rem" class="mb-3">🎭</div>
                    <h5 class="fw-bold">No events yet</h5>
                    <p class="text-muted">Create your first event to start selling tickets.</p>
                    <a asp-controller="Events" asp-action="Create" class="btn btn-primary mt-2">Create Event</a>
                </div>
            }
            else
            {
                <div class="card border-0 shadow-sm" style="border-radius:12px; overflow:hidden">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead style="background:linear-gradient(135deg,#6c63ff,#48c6ef); color:#fff">
                                <tr>
                                    <th class="px-4 py-3">Event</th>
                                    <th class="py-3">Date</th>
                                    <th class="py-3">Status</th>
                                    <th class="py-3 text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ev in events)
                                {
                                    <tr>
                                        <td class="px-4 py-3">
                                            <div class="fw-semibold">@ev.Title</div>
                                            <small class="text-muted">@ev.Category · $@ev.Price</small>
                                        </td>
                                        <td class="py-3 text-muted small align-middle">
                                            @ev.Date.ToString("MMM d, yyyy")
                                        </td>
                                        <td class="py-3 align-middle">
                                            <span class="badge @(ev.Status == "Published" ? "bg-success" : "bg-warning text-dark")">
                                                @ev.Status
                                            </span>
                                        </td>
                                        <td class="py-3 align-middle">
                                            <div class="d-flex flex-wrap gap-1 justify-content-center">
                                                <!-- Edit — existing route: GET /Events/Edit/{id} -->
                                                <a asp-controller="Events" asp-action="Edit"
                                                   asp-route-id="@ev.EventId"
                                                   class="btn btn-sm btn-outline-primary" title="Edit event">
                                                    ✏️ Edit
                                                </a>

                                                <!-- Ticket Categories — existing route: GET /Events/TicketCategories/{id} -->
                                                <a asp-controller="Events" asp-action="TicketCategories"
                                                   asp-route-id="@ev.EventId"
                                                   class="btn btn-sm btn-outline-success" title="Manage ticket categories">
                                                    🎫 Tickets
                                                </a>

                                                <!-- Revenue — existing route: GET /Events/Revenue/{id} -->
                                                <a asp-controller="Events" asp-action="Revenue"
                                                   asp-route-id="@ev.EventId"
                                                   class="btn btn-sm btn-outline-warning" title="View revenue">
                                                    💰 Revenue
                                                </a>

                                                <!-- Attendance — existing route: GET /Events/Attendance/{id} -->
                                                <a asp-controller="Events" asp-action="Attendance"
                                                   asp-route-id="@ev.EventId"
                                                   class="btn btn-sm btn-outline-info" title="View attendance">
                                                    📊 Attendance
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <div class="alert alert-info mt-4">
                <strong>💡 Tip:</strong> After creating an event, click <strong>🎫 Tickets</strong> to add pricing — then use <strong>Edit → 🚀 Publish</strong> for attendees to book.
            </div>
        </div>
    </div>
</div>
