<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventBooking</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <style>
        :root { --primary: #3B82F6; --primary-dark: #1D4ED8; }
        .navbar-brand { font-weight: 700; font-size: 1.3rem; }
        .nav-link { font-weight: 500; }
        .btn-primary { background: var(--primary); border-color: var(--primary); }
        .btn-primary:hover { background: var(--primary-dark); border-color: var(--primary-dark); }
        .badge-role { font-size: .65rem; vertical-align: middle; }
    </style>
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg navbar-dark shadow-sm" style="background:#1e293b">
        <div class="container">
            <a class="navbar-brand text-white" asp-controller="Home" asp-action="Index">
                🎟 EventBooking
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-controller="Events" asp-action="Index">Events</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white-50" asp-controller="Inquiry" asp-action="Create">Contact Us</a>
                    </li>
                </ul>
                <ul class="navbar-nav ms-auto align-items-center gap-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Attendee"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Dashboard" asp-action="Index">My Dashboard</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Booking" asp-action="MyBookings">My Bookings</a>
                            </li>
                        }
                        @if (User.IsInRole("Organizer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Organizer" asp-action="Index">Organizer Hub</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-white" asp-controller="Events" asp-action="Create">+ Create Event</a>
                            </li>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-warning fw-bold" asp-controller="Admin" asp-action="Index">⚙ Admin</a>
                            </li>
                        }
                        <li class="nav-item">
                            <span class="navbar-text text-white-50 small me-2">
                                @User.Identity!.Name
                                <span class="badge bg-primary badge-role ms-1">
                                    @(User.IsInRole("Admin") ? "Admin" : User.IsInRole("Organizer") ? "Organizer" : "Attendee")
                                </span>
                            </span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                <button type="submit" class="btn btn-outline-light btn-sm">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-light btn-sm">Login</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-0 rounded-0 text-center">
            @TempData["Success"]
            <button class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show mb-0 rounded-0 text-center">
            @TempData["Error"]
            <button class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @RenderBody()

    <footer class="py-4 mt-5 text-center text-muted small" style="background:#1e293b; color:#94a3b8!important">
        <div class="container">
            <span class="text-white-50">© @DateTime.Now.Year EventBooking · Find and book amazing events</span>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
