@model IEnumerable<EventBooking.BLL.DTOs.BookingDto>
@{
    ViewData["Title"] = "My Bookings";
}

<div class="container py-5" style="max-width:900px">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">🎟 My Bookings</h3>
        <a asp-controller="Events" asp-action="Index" class="btn btn-primary btn-sm">Browse Events</a>
    </div>

    @if (!Model.Any())
    {
        <div class="card border-0 shadow-sm p-5 text-center" style="border-radius:12px">
            <div class="display-1 mb-3">🎭</div>
            <h5 class="fw-bold">No bookings yet</h5>
            <p class="text-muted">Browse events and book your first ticket!</p>
            <a asp-controller="Events" asp-action="Index" class="btn btn-primary mt-2">Browse Events</a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var b in Model)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm" style="border-radius:12px">
                        <div class="card-body p-4">
                            <div class="row align-items-center">
                                <div class="col-md-7">
                                    <h5 class="fw-bold mb-1">@b.EventTitle</h5>
                                    <p class="text-muted small mb-1">📅 @b.EventDate.ToString("MMM d, yyyy")</p>
                                    <p class="text-muted small mb-1">📍 @b.Venue</p>
                                    <p class="text-muted small">🎟 @b.Quantity ticket(s) · Booked @b.BookingDate.ToString("MMM d, yyyy")</p>
                                </div>
                                <div class="col-md-2 text-center">
                                    <div class="fw-bold fs-5 text-primary">$@b.TotalPrice.ToString("F2")</div>
                                </div>
                                <div class="col-md-3 text-end">
                                    <span class="badge @(b.Status == "Confirmed" ? "bg-success" : b.Status == "Cancelled" ? "bg-danger" : "bg-warning text-dark") mb-2 d-block">
                                        @b.Status
                                    </span>
                                    @if (b.Status == "Confirmed")
                                    {
                                        <form asp-action="Cancel" asp-route-id="@b.BookingId" method="post">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger btn-sm"
                                                    onclick="return confirm('Cancel this booking?')">Cancel</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
