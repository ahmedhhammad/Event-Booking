@model IEnumerable<EventBooking.BLL.DTOs.TicketCategoryDto>
@{
    ViewData["Title"] = "Ticket Categories";
    Layout = "_TailwindLayout";
    var eventId = (int)ViewBag.EventId;
    var eventTitle = (string)(ViewBag.EventTitle ?? "");
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border-l-4 border-green-500 p-4 mb-6">
            <div class="flex">
                <div class="flex-shrink-0"><i data-lucide="check-circle" class="h-5 w-5 text-green-400"></i></div>
                <div class="ml-3"><p class="text-sm text-green-700">@TempData["Success"]</p></div>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6">
            <div class="flex">
                <div class="flex-shrink-0"><i data-lucide="alert-circle" class="h-5 w-5 text-red-400"></i></div>
                <div class="ml-3"><p class="text-sm text-red-700">@TempData["Error"]</p></div>
            </div>
        </div>
    }

    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div>
            <h3 class="text-2xl font-bold text-gray-900 flex items-center gap-2"><i data-lucide="ticket" class="size-6 text-blue-600"></i> Ticket Categories</h3>
            <p class="text-gray-500 mt-1">@eventTitle</p>
        </div>
        <a asp-action="Edit" asp-route-id="@eventId" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors shadow-sm">
            <i data-lucide="arrow-left" class="size-4"></i> Back to Event
        </a>
    </div>

    <!-- Existing categories -->
    @if (!Model.Any())
    {
        <div class="bg-amber-50 border-l-4 border-amber-500 p-4 mb-8">
            <div class="flex">
                <div class="flex-shrink-0"><i data-lucide="alert-triangle" class="h-5 w-5 text-amber-400"></i></div>
                <div class="ml-3"><p class="text-sm text-amber-700">No ticket categories yet. Add one below.</p></div>
            </div>
        </div>
    }
    else
    {
        <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden mb-8">
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm whitespace-nowrap">
                    <thead class="bg-gray-50 border-b border-gray-200 text-gray-500">
                        <tr>
                            <th class="px-6 py-4 font-medium">Name</th>
                            <th class="px-6 py-4 font-medium">Price</th>
                            <th class="px-6 py-4 font-medium">Available</th>
                            <th class="px-6 py-4 font-medium">Sold</th>
                            <th class="px-6 py-4 font-medium">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        @foreach (var tc in Model)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4 font-medium text-gray-900">@tc.Name</td>
                                <td class="px-6 py-4 text-gray-600">@tc.Price.ToString("C")</td>
                                <td class="px-6 py-4 text-gray-600">@tc.QuantityAvailable</td>
                                <td class="px-6 py-4">
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                        @tc.QuantitySold sold
                                    </span>
                                </td>
                                <td class="px-6 py-4">
                                    <form asp-action="EditTicketCategory" asp-route-id="@tc.TicketCategoryId" method="post" class="flex items-center gap-2 m-0">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="eventId" value="@eventId" />
                                        <input type="hidden" name="Name" value="@tc.Name" />
                                        <div class="relative">
                                            <div class="absolute inset-y-0 left-0 pl-2 flex items-center pointer-events-none"><span class="text-gray-500 sm:text-xs">$</span></div>
                                            <input type="number" step="0.01" min="0" name="Price" value="@tc.Price" class="w-24 pl-5 pr-2 py-1.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" />
                                        </div>
                                        <input type="number" min="0" name="QuantityAvailable" value="@tc.QuantityAvailable" class="w-20 px-2 py-1.5 border border-gray-300 rounded-lg text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" />
                                        <button type="submit" class="px-3 py-1.5 text-xs font-medium text-blue-700 bg-blue-50 border border-blue-200 rounded-lg hover:bg-blue-100 transition-colors">Update</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Add new category -->
    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
        <div class="bg-gray-50 border-b border-gray-200 px-6 py-4 flex items-center gap-2">
            <i data-lucide="plus" class="size-5 text-gray-500"></i>
            <h4 class="font-semibold text-gray-900">Add Ticket Category</h4>
        </div>
        <div class="p-6">
            <form asp-action="AddTicketCategory" asp-route-id="@eventId" method="post">
                @Html.AntiForgeryToken()
                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 items-end">
                    <div class="md:col-span-4">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                        <input name="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" placeholder="e.g. VIP, General" required />
                    </div>
                    <div class="md:col-span-3">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Price ($)</label>
                        <input name="Price" type="number" step="0.01" min="0" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" value="0" required />
                    </div>
                    <div class="md:col-span-3">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Qty Available</label>
                        <input name="QuantityAvailable" type="number" min="1" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required />
                    </div>
                    <div class="md:col-span-2">
                        <button type="submit" class="w-full bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors font-medium shadow-sm">
                            Add
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
