@model EventBooking.BLL.DTOs.PagedResultDto<EventBooking.BLL.DTOs.EventDto>
@{
    ViewData["Title"] = "Manage Events";
}

<div class="d-flex" style="min-height:calc(100vh - 62px)">
    <aside style="width:240px; background:#1e293b; flex-shrink:0; position:sticky; top:62px; height:calc(100vh - 62px); overflow-y:auto">
        <div class="p-4">
            <div class="text-white fw-bold mb-4">⚙ Admin Panel</div>
            <nav class="d-flex flex-column gap-1">
                <a asp-controller="Admin" asp-action="Index"   class="d-flex align-items-center gap-2 px-3 py-2 rounded text-decoration-none fw-medium" style="color:#94a3b8">📊 Dashboard</a>
                <a asp-controller="Admin" asp-action="Events"  class="d-flex align-items-center gap-2 px-3 py-2 rounded text-decoration-none fw-medium" style="color:#fff; background:#3B82F6">🎭 Events</a>
                <a asp-controller="Admin" asp-action="Users"   class="d-flex align-items-center gap-2 px-3 py-2 rounded text-decoration-none fw-medium" style="color:#94a3b8">👥 Users</a>
                <a asp-controller="Admin" asp-action="Reports" class="d-flex align-items-center gap-2 px-3 py-2 rounded text-decoration-none fw-medium" style="color:#94a3b8">📈 Reports</a>
            </nav>
        </div>
    </aside>

    <main class="flex-grow-1 p-4" style="background:#f8fafc">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="fw-bold mb-0">Event Management</h4>
                <p class="text-muted small mb-0">@Model.TotalCount events on the platform</p>
            </div>
            <a asp-controller="Events" asp-action="Create" class="btn btn-primary btn-sm">+ Create Event</a>
        </div>

        <div class="card border-0 shadow-sm" style="border-radius:12px">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead style="background:#1e293b; color:#fff">
                        <tr>
                            <th class="px-4 py-3">Title</th>
                            <th class="py-3">Category</th>
                            <th class="py-3">Date</th>
                            <th class="py-3">Status</th>
                            <th class="py-3">Price</th>
                            <th class="py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ev in Model.Items)
                        {
                            <tr>
                                <td class="px-4 py-3 fw-semibold">@ev.Title</td>
                                <td class="py-3"><span class="badge bg-secondary">@ev.Category</span></td>
                                <td class="py-3 text-muted small">@ev.Date.ToString("MMM d, yyyy")</td>
                                <td class="py-3">
                                    <span class="badge @(ev.Status == "Published" ? "bg-success" : "bg-warning text-dark")">@ev.Status</span>
                                </td>
                                <td class="py-3">$@ev.Price</td>
                                <td class="py-3">
                                    <a asp-controller="Events" asp-action="Edit" asp-route-id="@ev.EventId"
                                       class="btn btn-sm btn-outline-primary me-1">Edit</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>
