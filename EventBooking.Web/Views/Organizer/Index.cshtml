@model IEnumerable<EventBooking.BLL.DTOs.EventDto>
@{
    ViewData["Title"] = "Organizer Hub";
    Layout = "_TailwindLayout";
    var name = User.Identity?.Name ?? "Organizer";
    var events = Model.ToList();
}

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
        <div class="flex items-center gap-4">
            <div class="size-16 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 font-bold text-2xl">
                @name.Substring(0, 1).ToUpper()
            </div>
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Welcome back, @name.Split(' ')[0]! 👋</h1>
                <p class="text-gray-500 text-sm">@events.Count event(s) — click an action to manage it</p>
            </div>
        </div>
        <a asp-controller="Events" asp-action="Create" class="inline-flex items-center gap-2 bg-blue-600 text-white px-5 py-2.5 rounded-xl hover:bg-blue-700 transition-colors font-medium shadow-sm">
            <i data-lucide="plus-circle" class="size-5"></i> Create Event
        </a>
    </div>

    @if (!events.Any())
    {
        <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-12 text-center">
            <div class="size-16 bg-blue-50 text-blue-500 rounded-full flex items-center justify-center mx-auto mb-4">
                <i data-lucide="calendar" class="size-8"></i>
            </div>
            <h2 class="text-xl font-bold text-gray-900 mb-2">No events yet</h2>
            <p class="text-gray-500 mb-6 max-w-md mx-auto">You haven't created any events. Create your first event to start selling tickets and tracking attendance.</p>
            <a asp-controller="Events" asp-action="Create" class="inline-flex items-center gap-2 bg-blue-600 text-white px-6 py-3 rounded-xl hover:bg-blue-700 transition-colors font-medium shadow-sm">
                <i data-lucide="plus" class="size-5"></i> Create Your First Event
            </a>
        </div>
    }
    else
    {
        <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm whitespace-nowrap">
                    <thead class="bg-gray-50 border-b border-gray-200 text-gray-500">
                        <tr>
                            <th class="px-6 py-4 font-medium">Event</th>
                            <th class="px-6 py-4 font-medium">Date</th>
                            <th class="px-6 py-4 font-medium">Status</th>
                            <th class="px-6 py-4 font-medium text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-gray-200">
                        @foreach (var ev in events)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="font-medium text-gray-900">@ev.Title</div>
                                    <div class="text-gray-500 text-xs mt-0.5">@ev.Category &middot; $@ev.Price</div>
                                </td>
                                <td class="px-6 py-4 text-gray-600">
                                    @ev.Date.ToString("MMM d, yyyy")
                                </td>
                                <td class="px-6 py-4">
                                    @if (ev.Status == "Published")
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-700">
                                            <span class="size-1.5 rounded-full bg-green-500"></span> Published
                                        </span>
                                    }
                                    else if (ev.Status == "Cancelled")
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-100 text-red-700">
                                            <span class="size-1.5 rounded-full bg-red-500"></span> Cancelled
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-amber-100 text-amber-700">
                                            <span class="size-1.5 rounded-full bg-amber-500"></span> @ev.Status
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-end gap-2">
                                        <a asp-controller="Events" asp-action="Edit" asp-route-id="@ev.EventId"
                                           class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-white border border-gray-200 text-gray-700 rounded-lg hover:bg-gray-50 hover:text-blue-600 transition-colors shadow-sm" title="Edit">
                                            <i data-lucide="edit" class="size-3.5"></i> Edit
                                        </a>
                                        <a asp-controller="Events" asp-action="TicketCategories" asp-route-id="@ev.EventId"
                                           class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-white border border-gray-200 text-gray-700 rounded-lg hover:bg-gray-50 hover:text-green-600 transition-colors shadow-sm" title="Tickets">
                                            <i data-lucide="ticket" class="size-3.5"></i> Tickets
                                        </a>
                                        <a asp-controller="Events" asp-action="Revenue" asp-route-id="@ev.EventId"
                                           class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-white border border-gray-200 text-gray-700 rounded-lg hover:bg-gray-50 hover:text-amber-600 transition-colors shadow-sm" title="Revenue">
                                            <i data-lucide="circle-dollar-sign" class="size-3.5"></i> Revenue
                                        </a>
                                        <a asp-controller="Events" asp-action="Attendance" asp-route-id="@ev.EventId"
                                           class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium bg-white border border-gray-200 text-gray-700 rounded-lg hover:bg-gray-50 hover:text-purple-600 transition-colors shadow-sm" title="Attendance">
                                            <i data-lucide="users" class="size-3.5"></i> Attendance
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-xl p-5 text-sm text-blue-700 flex gap-3 items-start">
        <i data-lucide="lightbulb" class="size-5 flex-shrink-0 text-blue-600"></i>
        <div>
            <strong>Tip:</strong> After creating an event, click <strong>Tickets</strong> to add pricing — then use <strong>Edit &rarr; Publish</strong> for attendees to book.
        </div>
    </div>
</div>
