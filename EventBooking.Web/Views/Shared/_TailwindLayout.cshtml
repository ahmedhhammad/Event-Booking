<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EventBook</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style type="text/tailwindcss">
        @@layer utilities {
            .size-4 { width: 1rem; height: 1rem; }
            .size-5 { width: 1.25rem; height: 1.25rem; }
            .size-6 { width: 1.5rem; height: 1.5rem; }
            .size-8 { width: 2rem; height: 2rem; }
            .size-12 { width: 3rem; height: 3rem; }
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">

    <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Logo -->
                <a href="/" class="flex items-center gap-2">
                    <i data-lucide="ticket" class="size-8 text-blue-600"></i>
                    <span class="text-xl font-semibold text-gray-900">EventBook</span>
                </a>

                <!-- Desktop Navigation -->
                <nav class="hidden md:flex items-center gap-8">
                    <a href="/" class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Home</a>
                    <a href="/events" class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Events</a>
                    <a href="/contact" class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Contact</a>
                </nav>

                <!-- Right side -->
                <div class="hidden md:flex items-center gap-3">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Attendee"))
                        {
                            <a href="/dashboard" class="text-sm flex items-center gap-1 text-gray-600 hover:text-gray-900 transition-colors">
                                <i data-lucide="layout-dashboard" class="size-4"></i> Dashboard
                            </a>
                        }
                        @if (User.IsInRole("Organizer"))
                        {
                            <a href="/Organizer" class="text-sm flex items-center gap-1 text-gray-600 hover:text-gray-900 transition-colors">
                                <i data-lucide="settings" class="size-4"></i> Organizer Hub
                            </a>
                        }
                        @if (User.IsInRole("Admin"))
                        {
                            <a href="/admin" class="text-sm flex items-center gap-1 text-gray-600 hover:text-gray-900 transition-colors">
                                <i data-lucide="settings" class="size-4"></i> Admin
                            </a>
                        }
                        <div class="flex items-center gap-2 pl-3 border-l border-gray-200">
                            <i data-lucide="user-circle" class="size-5 text-gray-500"></i>
                            <span class="text-sm text-gray-700 font-medium">@User.Identity.Name</span>
                            <span class="text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded-full">
                                @(User.IsInRole("Admin") ? "Admin" : User.IsInRole("Organizer") ? "Organizer" : "Attendee")
                            </span>
                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0 p-0">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="text-sm flex items-center gap-1 text-gray-500 hover:text-red-600 transition-colors ml-1 bg-transparent border-0 cursor-pointer">
                                    <i data-lucide="log-out" class="size-4"></i>
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <a href="/login" class="text-sm text-gray-600 hover:text-gray-900 transition-colors">Login</a>
                        <a href="/register" class="text-sm bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors">
                            Get Started
                        </a>
                    }
                </div>
            </div>
        </div>
    </header>

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border-l-4 border-green-500 p-4 mb-4 mx-auto max-w-7xl mt-4">
            <div class="flex">
                <div class="flex-shrink-0">
                    <i data-lucide="check-circle" class="h-5 w-5 text-green-400"></i>
                </div>
                <div class="ml-3">
                    <p class="text-sm text-green-700">@TempData["Success"]</p>
                </div>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-4 mx-auto max-w-7xl mt-4">
            <div class="flex">
                <div class="flex-shrink-0">
                    <i data-lucide="alert-circle" class="h-5 w-5 text-red-400"></i>
                </div>
                <div class="ml-3">
                    <p class="text-sm text-red-700">@TempData["Error"]</p>
                </div>
            </div>
        </div>
    }

    <main class="flex-grow">
        @RenderBody()
    </main>

    <footer class="bg-gray-900 text-gray-300 mt-auto">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
                <!-- About -->
                <div>
                    <div class="flex items-center gap-2 mb-4">
                        <i data-lucide="ticket" class="size-6 text-blue-500"></i>
                        <span class="text-xl font-semibold text-white">EventBook</span>
                    </div>
                    <p class="text-sm text-gray-400">
                        Your premier destination for discovering and booking amazing events. Join thousands of event-goers worldwide.
                    </p>
                </div>

                <!-- Quick Links -->
                <div>
                    <h3 class="text-white font-semibold mb-4">Quick Links</h3>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/" class="hover:text-white transition-colors">Home</a></li>
                        <li><a href="/events" class="hover:text-white transition-colors">Events</a></li>
                        <li><a href="/dashboard" class="hover:text-white transition-colors">Dashboard</a></li>
                        <li><a href="/login" class="hover:text-white transition-colors">Login</a></li>
                    </ul>
                </div>

                <!-- Categories -->
                <div>
                    <h3 class="text-white font-semibold mb-4">Categories</h3>
                    <ul class="space-y-2 text-sm">
                        <li><a href="/events?category=Music" class="hover:text-white transition-colors">Music</a></li>
                        <li><a href="/events?category=Technology" class="hover:text-white transition-colors">Technology</a></li>
                        <li><a href="/events?category=Food" class="hover:text-white transition-colors">Food &amp; Drink</a></li>
                        <li><a href="/events?category=Sports" class="hover:text-white transition-colors">Sports</a></li>
                    </ul>
                </div>

                <!-- Contact -->
                <div>
                    <h3 class="text-white font-semibold mb-4">Contact Us</h3>
                    <ul class="space-y-3 text-sm">
                        <li class="flex items-start gap-2"><i data-lucide="mail" class="size-4 mt-0.5 flex-shrink-0"></i><span>support@eventbook.com</span></li>
                        <li class="flex items-start gap-2"><i data-lucide="phone" class="size-4 mt-0.5 flex-shrink-0"></i><span>+20 0155555555</span></li>
                        <li class="flex items-start gap-2"><i data-lucide="map-pin" class="size-4 mt-0.5 flex-shrink-0"></i><span>55 Mohammed Mazhar Street , Cairo</span></li>
                    </ul>
                    <div class="flex gap-4 mt-4">
                        <a href="#" class="hover:text-white transition-colors"><i data-lucide="facebook" class="size-5"></i></a>
                        <a href="#" class="hover:text-white transition-colors"><i data-lucide="twitter" class="size-5"></i></a>
                        <a href="#" class="hover:text-white transition-colors"><i data-lucide="instagram" class="size-5"></i></a>
                        <a href="#" class="hover:text-white transition-colors"><i data-lucide="linkedin" class="size-5"></i></a>
                    </div>
                </div>
            </div>
            <div class="border-t border-gray-800 mt-8 pt-8 text-sm text-center text-gray-400">
                <p>© @DateTime.Now.Year EventBook. All rights reserved. | <a href="#" class="hover:text-white">Privacy Policy</a> | <a href="#" class="hover:text-white">Terms of Service</a></p>
            </div>
        </div>
    </footer>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script>
        lucide.createIcons();
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
