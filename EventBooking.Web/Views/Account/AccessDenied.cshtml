@{
    ViewData["Title"] = "Access Denied";
}

<div class="container py-5 text-center" style="max-width:500px; margin:0 auto">
    <div style="font-size:4rem" class="mb-3">🚫</div>
    <h2 class="fw-bold mb-2">Access Denied</h2>
    <p class="text-muted mb-4">You don't have permission to view this page. Make sure you're logged in with the correct role.</p>
    <div class="d-flex gap-2 justify-content-center">
        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Go Home</a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">Login</a>
    </div>
</div>
