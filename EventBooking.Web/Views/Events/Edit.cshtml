@model EventBooking.BLL.DTOs.UpdateEventDto
@{
    ViewData["Title"] = "Edit Event";
    Layout = "_TailwindLayout";
    var eventId = (int)ViewBag.EventId;
    var status = (string)(ViewBag.EventStatus ?? "Draft");
    bool isDraft = status == "Draft";
    bool isCancelled = status == "Cancelled";
    bool isEditable = isDraft || isCancelled;
    string ro = isEditable ? "" : "readonly";
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    @if (isCancelled)
    {
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6">
            <div class="flex">
                <div class="flex-shrink-0">
                    <i data-lucide="alert-triangle" class="h-5 w-5 text-red-500"></i>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-red-800">Event is Cancelled</h3>
                    <div class="mt-2 text-sm text-red-700">
                        <p>This event has been cancelled and is hidden from attendees. You can edit the details and republish it.</p>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="bg-green-50 border-l-4 border-green-500 p-4 mb-6">
            <div class="flex">
                <div class="flex-shrink-0">
                    <i data-lucide="check-circle" class="h-5 w-5 text-green-400"></i>
                </div>
                <div class="ml-3">
                    <p class="text-sm text-green-700">@TempData["Success"]</p>
                </div>
            </div>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="bg-red-50 border-l-4 border-red-500 p-4 mb-6">
            <div class="flex">
                <div class="flex-shrink-0">
                    <i data-lucide="alert-circle" class="h-5 w-5 text-red-400"></i>
                </div>
                <div class="ml-3">
                    <p class="text-sm text-red-700">@TempData["Error"]</p>
                </div>
            </div>
        </div>
    }

    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden mb-6">
        <div class="bg-blue-600 text-white px-6 py-4 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <i data-lucide="edit" class="size-6"></i>
                <h4 class="text-xl font-bold">Edit Event</h4>
            </div>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium @(isDraft ? "bg-amber-100 text-amber-800" : (isCancelled ? "bg-red-100 text-red-800" : "bg-green-100 text-green-800"))">
                <span class="size-1.5 rounded-full @(isDraft ? "bg-amber-500" : (isCancelled ? "bg-red-500" : "bg-green-500"))"></span> @status
            </span>
        </div>
        <div class="p-6 sm:p-8">
            <form asp-action="Edit" asp-route-id="@eventId" method="post" class="space-y-6">
                @Html.AntiForgeryToken()

                <div>
                    <label asp-for="Title" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    @if (isEditable)
                    { <input asp-for="Title" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" required /> }
                    else
                    { <input asp-for="Title" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-50 text-gray-500" readonly /> }
                </div>

                <div>
                    <label asp-for="Description" class="block text-sm font-medium text-gray-700 mb-1"></label>
                    @if (isEditable)
                    { <textarea asp-for="Description" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" rows="3"></textarea> }
                    else
                    { <textarea asp-for="Description" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-50 text-gray-500" rows="3" readonly></textarea> }
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label asp-for="Category" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        @if (isEditable)
                        {
                            <select asp-for="Category" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors bg-white">
                                @foreach (var c in new[]{"Music", "Technology", "Food", "Art", "Sports", "Entertainment", "Business"})
                                { <option value="@c">@c</option> }
                            </select>
                        }
                        else
                        { <input asp-for="Category" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-50 text-gray-500" readonly /> }
                    </div>
                    <div>
                        <label asp-for="Venue" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        @if (isEditable)
                        { <input asp-for="Venue" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" /> }
                        else
                        { <input asp-for="Venue" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-50 text-gray-500" readonly /> }
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div>
                        <label asp-for="Date" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        @if (isEditable)
                        { <input asp-for="Date" type="datetime-local" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" /> }
                        else
                        { <input asp-for="Date" type="datetime-local" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-50 text-gray-500" readonly /> }
                    </div>
                    <div>
                        <label asp-for="Capacity" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        @if (isEditable)
                        { <input asp-for="Capacity" type="number" min="1" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" /> }
                        else
                        { <input asp-for="Capacity" type="number" class="w-full px-4 py-2 border border-gray-300 rounded-lg bg-gray-50 text-gray-500" readonly /> }
                    </div>
                    <div>
                        <label asp-for="Price" class="block text-sm font-medium text-gray-700 mb-1"></label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <span class="text-gray-500 sm:text-sm">$</span>
                            </div>
                            @if (isEditable)
                            { <input asp-for="Price" type="number" step="0.01" min="0" class="w-full pl-7 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors" /> }
                            else
                            { <input asp-for="Price" type="number" step="0.01" class="w-full pl-7 pr-4 py-2 border border-gray-300 rounded-lg bg-gray-50 text-gray-500" readonly /> }
                        </div>
                    </div>
                </div>

                @if (isEditable)
                {
                    <div class="pt-2">
                        <button type="submit" class="bg-blue-600 text-white px-6 py-2.5 rounded-lg hover:bg-blue-700 transition-colors font-medium shadow-sm">
                            Save Changes
                        </button>
                    </div>
                }
            </form>
        </div>
    </div>

    <!-- Action links -->
    <div class="flex flex-wrap items-center gap-3">
        <a asp-action="TicketCategories" asp-route-id="@eventId" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-green-600 transition-colors shadow-sm">
            <i data-lucide="ticket" class="size-4"></i> Ticket Categories
        </a>
        <a asp-action="Revenue" asp-route-id="@eventId" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-amber-600 transition-colors shadow-sm">
            <i data-lucide="circle-dollar-sign" class="size-4"></i> Revenue
        </a>
        <a asp-action="Attendance" asp-route-id="@eventId" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 hover:text-purple-600 transition-colors shadow-sm">
            <i data-lucide="users" class="size-4"></i> Attendance
        </a>
        @if (isDraft)
        {
            <form asp-action="Publish" asp-route-id="@eventId" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-green-600 border border-transparent rounded-lg hover:bg-green-700 transition-colors shadow-sm"
                        onclick="return confirm('Publish this event? This cannot be undone.')">
                    <i data-lucide="rocket" class="size-4"></i> Publish Event
                </button>
            </form>
        }
        @if (status == "Published")
        {
            <form asp-action="Cancel" asp-route-id="@eventId" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-red-600 border border-transparent rounded-lg hover:bg-red-700 transition-colors shadow-sm"
                        onclick="return confirm('WARNING: Cancelling this event will refund all paid attendees and send them an email notification. This cannot be undone. Continue?')">
                    <i data-lucide="x-circle" class="size-4"></i> Cancel Event
                </button>
            </form>
        }
        @if (isCancelled)
        {
            <form asp-action="Republish" asp-route-id="@eventId" method="post" class="m-0">
                @Html.AntiForgeryToken()
                <button type="submit" class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors shadow-sm">
                    <i data-lucide="refresh-cw" class="size-4"></i> Republish
                </button>
            </form>
        }
        <a asp-action="Index" asp-controller="Organizer" class="ml-auto inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 transition-colors shadow-sm">
            <i data-lucide="arrow-left" class="size-4"></i> Back to Events
        </a>
    </div>
</div>
